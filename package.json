{
  "name": "docket",
  "productName": "Docket",
  "version": "0.1.18",
  "description": "Native macOS markdown docs browser with checklist support",
  "main": "main.js",
  "author": "Matt Wallington",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "test": "node --test test/",
    "test:security": "node scripts/verify-security.js",
    "test:golden": "node scripts/verify-golden-path.js",
    "test:cli": "node scripts/verify-cli-arg.js",
    "build:icon": "node scripts/build-icon.js",
    "build": "node scripts/build-with-version.js && electron-builder --mac",
    "release": "./scripts/release.sh",
    "postinstall": "node scripts/copy-vendor.js || true"
  },
  "devDependencies": {
    "@highlightjs/cdn-assets": "11.10.0",
    "electron": "^32.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.15.9",
    "chokidar": "^3.6.0",
    "dompurify": "^3.1.6",
    "electron-updater": "^6.8.3",
    "highlight.js": "^11.11.1",
    "marked": "^12.0.2"
  },
  "build": {
    "appId": "com.mattwallington.docket",
    "productName": "Docket",
    "publish": {
      "provider": "github",
      "owner": "mattwallington",
      "repo": "docket"
    },
    "artifactName": "${name}-${version}-${arch}-${os}.${ext}",
    "mac": {
      "category": "public.app-category.productivity",
      "identity": "Matthew Wallington (5S875AN2HU)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.plist",
      "entitlementsInherit": "entitlements.plist",
      "notarize": {
        "teamId": "5S875AN2HU"
      },
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "extendInfo": {
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "Markdown Document",
            "CFBundleTypeRole": "Viewer",
            "LSHandlerRank": "Alternate",
            "LSItemContentTypes": [
              "public.markdown",
              "net.daringfireball.markdown"
            ]
          }
        ]
      }
    },
    "files": [
      "**/*",
      "!scripts/create-installer.js",
      "!scripts/build-icon.js",
      "!scripts/verify-security.js",
      "!scripts/verify-golden-path.js",
      "!test/**",
      "!docs/**",
      "!assets/icon.iconset/**",
      "!assets/icon-dev.iconset/**",
      "!assets/icon-dev.icns",
      "!assets/icon-dev.svg",
      "!assets/icon.svg",
      "build-info.json"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
